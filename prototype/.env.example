# Prototype runs entirely on mock data — none of these are required.
# Fill them in only when wiring real services per JJKC_algorithm/plan.md.

# NextAuth (deferred — auth is currently a cookie-based demo stub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Postgres (Neon) — replace lib/mock-data.ts with Prisma queries when set
DATABASE_URL=

# Upstash Redis — wrap YouTube API calls when wired
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# YouTube Data API v3 (separate from OAuth client)
YOUTUBE_API_KEY=
